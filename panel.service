[Unit]
Description=Mihomo Web Panel
After=network-online.target mihomo.service
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/n1-panel
EnvironmentFile=-/etc/n1-panel/env
ExecStart=/usr/bin/python3 /opt/panel/app.py
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
